# Environment variable overrides — .env.example files ARE committed
# backend/.env is gitignored (contains DB creds only needed locally)
# frontend/.env is NOT gitignored so the Docker build can read VITE_API_BASE_URL
backend/.env
!frontend/.env
!.env.example

